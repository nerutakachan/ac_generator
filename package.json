{
  "name": "ac-file-generator",
  "version": "0.0.3",
  "repository": {
    "type": "git",
    "url": "https://github.com/takashi1128f-create/ac_generator.git"
  },
	"devDependencies": {
		"electron": "^28.3.3",
		"electron-builder": "^24.13.3",
		"electron-reload": "^2.0.0-alpha.1",
		"nodemon": "^3.1.14"
	},
	"build": {
    "appId": "com.example.ac-file-generator",
    "publish": [
      {
        "provider": "github",
        "owner": "takashi1128f-create",
        "repo": "ac_generator"
      }
    ],
		"nsis": {
			"oneClick": false,
			"perMachine": true,
			"allowToChangeInstallationDirectory": true,
			"createDesktopShortcut": true,
			"createStartMenuShortcut": true,
			"shortcutName": "AC FILE GENERATOR"
		}
	}
}
